# PostgreSQL connection
BOM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bom_platform

# Max upload size in bytes (default 100MB)
BOM_MAX_UPLOAD_BYTES=104857600

# Local storage path for uploaded BOM source files
BOM_FILE_STORAGE_DIR=./data/bom_files

# CORS
BOM_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
BOM_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
